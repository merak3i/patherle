# ──────────────────────────────────────────────────────────────
# Patherle Backend — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ──────────────────────────────────────────────────────────────

PORT=3000

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Pinecone (Vector Database) ───────────────────────────────
PINECONE_API_KEY=YOUR_PINECONE_API_KEY

# ─── AI / LLM providers ───────────────────────────────────────
SARVAM_API_KEY=YOUR_SARVAM_API_KEY           # Sarvam AI (LLM + Translation)
HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_API_KEY # BGE-m3 embeddings + Whisper STT

# ─── Meta / WhatsApp Cloud API ────────────────────────────────
# Per-tenant tokens are stored in the DB (tenants.whatsapp_token).
# The vars below are only used for single-tenant / dev setups.
WHATSAPP_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN
WHATSAPP_PHONE_ID=YOUR_WHATSAPP_PHONE_NUMBER_ID

# Webhook verification
WHATSAPP_VERIFY_TOKEN=YOUR_WEBHOOK_VERIFY_TOKEN

# HMAC-SHA256 payload signature verification (recommended in production)
# Found in Meta App Dashboard → Webhooks → App Secret
WHATSAPP_APP_SECRET=YOUR_META_APP_SECRET

# ─── Telegram Bot API ─────────────────────────────────────────
# Secret token sent in X-Telegram-Bot-Api-Secret-Token header (optional but recommended)
# Set the same value when registering the webhook:
#   POST https://api.telegram.org/bot<TOKEN>/setWebhook
#     { "url": "...", "secret_token": "YOUR_TELEGRAM_SECRET_TOKEN" }
TELEGRAM_SECRET_TOKEN=YOUR_TELEGRAM_WEBHOOK_SECRET

# ─── React Web Chatbot ────────────────────────────────────────
# Optional API key that gates access to POST /api/chat/web.
# Leave blank to allow unauthenticated access (dev only).
WEB_CHAT_API_KEY=YOUR_WEB_CHAT_API_KEY

# ─── Backend public URL ───────────────────────────────────────
# Used when auto-registering Telegram webhooks on startup.
BACKEND_URL=https://your-backend.railway.app

# ─── Queue tuning (optional) ──────────────────────────────────
QUEUE_MAX_CONCURRENT=10    # max parallel LLM tasks (default: 10)
QUEUE_TASK_TIMEOUT_MS=120000 # per-task timeout in ms (default: 120 000)

# ─── Rate limiting (optional) ─────────────────────────────────
WEB_CHAT_RPM=30            # max requests/min per web session (default: 30)

# ─── Cloudflare Browser Rendering (Tier 2/3 website crawl) ────
# API Token: Cloudflare Dashboard → My Profile → API Tokens
CF_API_TOKEN=XVbRKCLABWxBlVNlr9Of5Bsy2QBfanT_T2qF5DRn
# Account ID: Cloudflare Dashboard → Overview → Account ID (right sidebar)
CF_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID

# ─── Cron job security ─────────────────────────────────────────
# Pass as X-Cron-Secret header when calling GET /api/cron/sync-catalogs
CRON_SECRET=YOUR_STRONG_RANDOM_SECRET
